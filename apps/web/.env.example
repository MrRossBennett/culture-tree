VITE_BASE_URL=http://localhost:3000

# Prefer 127.0.0.1 over localhost with Docker + Node (avoids IPv6 ::1 connection refused).
DATABASE_URL="postgresql://postgres:password@127.0.0.1:5432/tanstarter"
# You can also use Docker Compose to set up a local PostgreSQL database:
# docker-compose up -d

# vp run auth:secret
BETTER_AUTH_SECRET=

# OAuth2 providers, optional, update as needed
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Culture Tree generation (Claude via AI SDK)
ANTHROPIC_API_KEY=

# When true, generation uses committed JSON fixtures (no LLM calls). See docs/MONOREPO.md.
MOCK_ENGINE=false

# Enrichment (server-side; optional keys improve rate limits / data quality)
# TMDB — use ONE of these (see https://www.themoviedb.org/settings/api )
# API Read Access Token (JWT) → Bearer auth
TMDB_ACCESS_TOKEN=
# OR v3 API Key → ?api_key=… (do not put the API key in TMDB_ACCESS_TOKEN)
# TMDB_API_KEY=
# Google Books — optional; unauthenticated quota is lower
GOOGLE_BOOKS_API_KEY=
# MusicBrainz — only if you switch `pipeline.ts` back to `music.ts` enrichers
# MUSICBRAINZ_USER_AGENT=CultureTree/0.1 (you@example.com)

# NOTE:
# In your OAuth2 apps, set callback/redirect URIs to`http://localhost:3000/api/auth/callback/<provider>`
# e.g. http://localhost:3000/api/auth/callback/github